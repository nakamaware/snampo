# ローカル開発用のシークレット設定
# このファイルをコピーして secrets.auto.tfvars を作成し、実際の値を入力

billing_account_id = "XXXXXX-XXXXXXX-XXXXXXX-XXXXXX"

# Discord のロール ID (Discord のチャンネル設定でロールを右クリック → ID をコピー (discord管理者のみ))
discord_role_id = "000000000000000000"

# Discord チャンネルの Webhook URL (チャンネル設定 → 連携サービス → ウェブフック)
discord_webhook_url = "https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN"
